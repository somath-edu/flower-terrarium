---
import CornellNote from '../../components/CornellNote.astro';

// 모든 수식을 변수로 격리하여 Astro 컴파일러 에러 방지 및 시각적 품질 향상
const mathType01 = "$ f(x) = \\begin{cases} \\displaystyle \\frac{x^2+ax+b}{x-2} & (x \\neq 2) \\\\ 5 & (x = 2) \\end{cases} $";
const mathType02 = "$ f(x) = \\begin{cases} ax+b & (x < 1) \\\\ x^2+2 & (1 \\le x < 2) \\\\ bx+a & (x \\ge 2) \\end{cases} $";
const mathType03 = "$ f(x) = \\begin{cases} \\displaystyle \\frac{x^2+ax+b}{x-2} & (x \\neq 2) \\\\ 5 & (x = 2) \\end{cases} $";
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>실전 연습 - 구간별 함수의 연속</title>
		<!-- KaTeX (Safe CDN) -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
		<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
		<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"></script>
		<style>
			body {
				background-color: #e0e0e0;
				margin: 0;
				padding: 20px;
				display: flex;
				justify-content: center;
			}
			.solution {
				color: #444;
				background-color: rgba(0,0,0,0.02);
				padding: 10px 15px;
				border-left: 3px solid #ccc;
				margin: 10px 0;
			}
			/* [표준 디자인 시스템] KaTeX & 모바일 수식 최적화 */
			.formula-box {
				text-align: center;
				margin: 30px 0;
				background: #fff;
				padding: 30px;
				border-radius: 12px;
				border: 1px solid #eee;
				box-shadow: 0 2px 8px rgba(0,0,0,0.02);
				overflow: hidden;
				width: 100%;
				box-sizing: border-box;
			}
			.math-container {
				width: 100%;
				overflow-x: auto;
				white-space: nowrap;
				-webkit-overflow-scrolling: touch;
				padding-bottom: 10px;
				display: flex;
				justify-content: center;
			}
			.katex-display {
				margin: 0.5em 0 !important;
				overflow-x: auto;
				overflow-y: hidden;
			}
			@media screen and (max-width: 480px) {
				.formula-box { padding: 15px 5px !important; margin: 20px 0 !important; }
				.katex-display { font-size: 0.85em !important; }
				.formula-box p { font-size: 1rem !important; line-height: 1.5; }
				body { padding: 10px; }
				
				.type-header h4 { font-size: 1.1rem !important; }
				.problem-link { font-size: 0.8rem !important; padding: 3px 10px !important; }
			}
		</style>
	</head>
	<body>
		<CornellNote title="구간별 함수의 연속" chapter="Chapter 01 Practice">
			
			<div slot="cues">
				<p style="margin: 0; font-weight: bold; color: #1a1a1a;">🚀 해결 전략 체크리스트</p>
				<ul style="margin-top: 10px; padding-left: 18px; font-size: 11pt; line-height: 1.6; color: #444;">
					<li>경계점(식의 경계)이 어디인가?</li>
					<li>좌극한과 우극한이 같은가?</li>
					<li>경계에서의 함숫값이 존재하는가?</li>
					<li>모든 실수에서 연속임을 활용하는가?</li>
				</ul>
			</div>

			<section>
				<!-- Type 01 -->
				<div class="type-section" id="type01">
					<div class="type-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
						<h4 style="margin: 0; color: #1a1a1a; border-bottom: 2px solid royalblue; display: inline-block; padding-bottom: 5px;">
							유형 01. 미정계수의 결정
						</h4>
						<a href="/wiki/chapter01/types/type08/" class="problem-link">연습 ✏️</a>
					</div>
					<p>함수 $f(x)$가 $x=a$에서 연속일 조건을 이용하여 미지수를 구하시오.</p>
					<div class="formula-box">
						<div class="math-container">
							<span set:html={"$$ f(x) = \\begin{cases} \\displaystyle \\frac{x^2+ax+b}{x-2} & (x \\neq 2) \\\\ 5 & (x = 2) \\end{cases} $$"}></span>
						</div>
						<p style="margin-top: 10px; color: #333; word-break: keep-all;">가 $x=2$에서 연속일 때, $a, b$의 값은?</p>
					</div>
				</div>

				<!-- Type 02 -->
				<div class="type-section" id="type02" style="margin-top: 50px;">
					<div class="type-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
						<h4 style="margin: 0; color: #1a1a1a; border-bottom: 2px solid royalblue; display: inline-block; padding-bottom: 5px;">
							유형 02. 연립방정식을 이용한 연속 조건
						</h4>
						<a href="/wiki/chapter01/types/type09/" class="problem-link">연습 ✏️</a>
					</div>
					<p>경계가 두 곳이거나 미지수가 여러 개인 경우 연립방정식을 세워 해결합니다.</p>
					<div class="formula-box">
						<div class="math-container">
							<span set:html={"$$ f(x) = \\begin{cases} ax+b & (x < 1) \\\\ x^2+2 & (1 \\le x < 2) \\\\ bx+a & (x \\ge 2) \\end{cases} $$"}></span>
						</div>
						<p style="margin-top: 10px; color: #333; word-break: keep-all;">가 모든 실수 $x$에서 연속일 때, $a, b$의 값은?</p>
					</div>
				</div>

				<!-- Type 03 -->
				<div class="type-section" id="type03" style="margin-top: 50px;">
					<div class="type-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
						<h4 style="margin: 0; color: #1a1a1a; border-bottom: 2px solid royalblue; display: inline-block; padding-bottom: 5px;">
							유형 03. 함숫값이 따로 정의된 함수의 연속
						</h4>
						<a href="/wiki/chapter01/types/type10/" class="problem-link">연습 ✏️</a>
					</div>
					<p>분수 함수 형태와 특정 지점의 함숫값을 비교하는 고난도 유형입니다.</p>
					<div class="formula-box">
						<div class="math-container">
							<span set:html={"$$ f(x) = \\begin{cases} \\displaystyle \\frac{x^2+ax+b}{x-2} & (x \\neq 2) \\\\ 5 & (x = 2) \\end{cases} $$"}></span>
						</div>
						<p style="margin-top: 10px; color: #333; word-break: keep-all;">가 $x=2$에서 연속일 때, $a+b$의 값은?</p>
					</div>
				</div>

				<a href="/wiki/chapter01/continuity/" class="back-link" style="margin-top: 50px; display: inline-block; color: royalblue; text-decoration: none; font-weight: bold;">← 개념 공부로 돌아가기</a>
			</section>

			<div slot="summary">
				<p>구간별 함수가 연속이 되려면 **'이음새'**가 매끄러워야 합니다. 경계값 $x=a$를 양쪽 식에 대입했을 때의 결과가 같다는 점을 이용하면 대부분의 문제를 해결할 수 있습니다.</p>
			</div>
		</CornellNote>

		<script is:inline>
			if (typeof window !== 'undefined') {
				document.addEventListener("DOMContentLoaded", function() {
					if (typeof renderMathInElement === 'function') {
						renderMathInElement(document.body, {
							delimiters: [
								{left: '$$', right: '$$', display: true},
								{left: '$', right: '$', display: false}
							],
							throwOnError : false
						});
					}
				});
			}
		</script>
	</body>
</html>
