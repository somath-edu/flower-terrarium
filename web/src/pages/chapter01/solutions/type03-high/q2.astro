import MathPageLayout from '../../../../layouts/MathPageLayout.astro';
import CornellNote from '../../../../components/CornellNote.astro';
---

<MathPageLayout title="유형 03 [수능] Q2 상세 해설">
  <CornellNote title="유형 03 [수능] Q2 상세 해설" chapter="Level: CSAT">
<div slot="cues">
<p style="margin: 0; font-weight: bold; color: #1a1a1a;">💡 풀이 전략</p>
				<p style="margin-top: 10px; font-size: 10pt; line-height: 1.6; color: #666;">
					함수의 차수를 먼저 결정한 뒤, 영인자 조건과 극한값 정보를 연립하여 미지수를 해결합니다.
				</p>
  </div>

  <section>
<div class="sol-box formula-box">
					<p style="margin-bottom: 20px; font-weight: bold;">Q2. 다항함수 { "$ f(x) $" }에 대하여 다음이 성립할 때, { "$ f(3) $" }의 값을 구하시오.</p>
					<div style="background: #fcfcfc; padding: 10px; border: 1px solid #f0f0f0; border-radius: 8px; margin: 15px 0;">
						(가) { "$ \\displaystyle \\lim_{x \\to \\infty} \\frac{f(x)-x^3}{x^2} = -2 $" }<br/>
						(나) { "$ \\displaystyle \\lim_{x \\to 2} \\frac{f(x)}{x-2} = 10 $" }
					</div>

					<span class="step-title">Step 1. 함수 구조 파악</span>
					<p>(가) 조건에 의해 { "$ f(x) $" }는 { "$ x^3 - 2x^2 + ax + b $" } 형태여야 합니다.</p>

					<span class="step-title">Step 2. 인수 정리 적용</span>
					<p>(나) 조건에 의해 { "$ f(2) = 0 $" }이므로:<br/>
					{ "$ 8 - 8 + 2a + b = 0 \\implies b = -2a $" }<br/>
					따라서 { "$ f(x) = x^3 - 2x^2 + ax - 2a = x^2(x-2) + a(x-2) = (x-2)(x^2 + a) $" }가 됩니다.</p>

					<span class="step-title">Step 3. 극한값 활용 및 계산</span>
					<p>{ "$ \\displaystyle \\lim_{x \\to 2} (x^2 + a) = 4 + a = 10 \\implies a = 6 $" }<br/>
					{ "$ f(x) = (x-2)(x^2 + 6) $" }이므로 { "$ f(3) = (3-2)(9 + 6) = 15 $" }입니다.</p>
				</div>

				<div style="text-align: center;">
					<a href="/wiki/chapter01/levels/type03-high/" class="problem-link mobile-nav-btn">← 문제로 돌아가기</a>
				</div>
  </section>
  </CornellNote>
</MathPageLayout>

