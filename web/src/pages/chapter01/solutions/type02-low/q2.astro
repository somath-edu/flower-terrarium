import MathPageLayout from '../../../../layouts/MathPageLayout.astro';
import CornellNote from '../../../../components/CornellNote.astro';
---

<MathPageLayout title="유형 02 [하] Q2 상세 해설">
  <CornellNote title="유형 02 [하] Q2 상세 해설" chapter="Solution">
<div slot="cues">
<p style="margin: 0; font-weight: bold; color: #1a1a1a;">💡 풀이 전략</p>
				<p style="margin-top: 10px; font-size: 10pt; line-height: 1.6; color: #666;">
					유리화 과정에서 분자의 최고차항 계수와 분모의 최고차항 계수비를 정확히 파악하는 것이 중요합니다.
				</p>
  </div>

  <section>
<div class="sol-box formula-box">
					<p style="margin-bottom: 20px; font-weight: bold;">Q2. 다음 극한값을 구하시오.</p>
					<p style="text-align: center; font-size: 1.25rem; background: #fcfcfc; padding: 10px; border-radius: 12px;">
						{ "$ \\displaystyle \\lim_{x \\to \\infty} (\\sqrt{x^2 + 4x} - x) $" }
					</p>

					<span class="step-title">Step 1. 유리화</span>
					<p>분모와 분자에 { "$ \\sqrt{x^2+4x}+x $" }를 곱합니다.<br/>
					{ "$ \\displaystyle \\lim_{x \\to \\infty} \\frac{(x^2+4x)-x^2}{\\sqrt{x^2+4x}+x} = \\lim_{x \\to \\infty} \\frac{4x}{\\sqrt{x^2+4x}+x} $" }</p>

					<span class="step-title">Step 2. 차수 비교</span>
					<p>분모와 분자의 최고차항이 { "$ 1 $" }차식입니다.<br/>
					분모의 최고차항 계수는 { "$ 1+1=2 $" }이고, 분자의 최고차항 계수는 { "$ 4 $" }입니다.</p>

					<span class="step-title">Step 3. 최종 정답</span>
					<p>{ "$ \\displaystyle \\frac{4}{2} = 2 $" }<br/>
					정답은 { "$ 2 $" }입니다.</p>
				</div>

				<div style="text-align: center;">
					<a href="/wiki/chapter01/levels/type02-low/" class="problem-link mobile-nav-btn">← 문제로 돌아가기</a>
				</div>
  </section>
  </CornellNote>
</MathPageLayout>

