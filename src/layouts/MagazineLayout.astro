---
// We attempt to load Capsize core & metrics.
import { createStyleObject } from '@capsizecss/core';

// Hardcoded approximate metrics for Noto KR fonts to guarantee resolution
const notoSansKrMetrics = {
  capHeight: 733, ascent: 1160, descent: -288, lineGap: 0, unitsPerEm: 1000
};
const notoSerifKrMetrics = {
  capHeight: 733, ascent: 1160, descent: -288, lineGap: 0, unitsPerEm: 1000
};

import { type CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  date: Date;
  category: string;
  coverImage: string;
  subImage: string;
  subtitle: string;
  description: string;
  titleEn?: string;
  categoryEn?: string;
  subtitleEn?: string;
  descriptionEn?: string;
}

const { 
  title, date, category, coverImage, subImage, subtitle, description, 
  titleEn, categoryEn, subtitleEn, descriptionEn 
} = Astro.props as Props;
const base = import.meta.env.BASE_URL;
const safeCover = coverImage ? `${base}/${coverImage.replace(/^\/+/, '')}`.replace('//', '/') : '';
const safeSub = subImage ? `${base}/${subImage.replace(/^\/+/, '')}`.replace('//', '/') : '';

// Create Capsize trimmed CSS styles 
const headerStyle = createStyleObject({
  fontSize: 44,
  leading: 50,
  fontMetrics: notoSerifKrMetrics
});

const bodyStyle = createStyleObject({
  fontSize: 11,
  leading: 18,
  fontMetrics: notoSansKrMetrics
});

---

<html lang="ko" data-theme="light" data-lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Magazine Blog</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700&family=Noto+Serif+KR:wght@400;500;600;700;800&family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,800&display=swap" rel="stylesheet">
    
    <style is:global define:vars={{
      // Dynamically pass Capsize logic to CSS Variables for usage
      valBefore: headerStyle['::before'].content,
      valAfter: headerStyle['::after'].content,
      marginBottomBefore: headerStyle['::before'].marginBottom,
      marginTopAfter: headerStyle['::after'].marginTop,
      
      bValBefore: bodyStyle['::before'].content,
      bValAfter: bodyStyle['::after'].content,
      bMarginBottomBefore: bodyStyle['::before'].marginBottom,
      bMarginTopAfter: bodyStyle['::after'].marginTop,
    }}>
      :root {
        /* Theme Constants */
        --theme-bg-light: #f1efe8;
        --theme-text-light: #1a202c;
        
        --theme-bg-dark: #1e1e1e;
        --theme-text-dark: #e2e8f0;
        
        --bg-color: var(--theme-bg-light);
        --text-color: var(--theme-text-light);
      }

      [data-theme="dark"] {
        --bg-color: var(--theme-bg-dark);
        --text-color: var(--theme-text-dark);
      }

      /* Hide active/inactive languages */
      [data-lang="ko"] .lang-en { display: none; }
      [data-lang="en"] .lang-ko { display: none; }

      body {
        margin: 0;
        padding: 40px 0;
        background-color: #2c3e50; /* desk background */
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }

      /* Typetura Container */
      .typetura-container {
        --tt-key: magazine;
        --tt-max: 794; /* 794px max canvas size */
        --tt-ease: linear;
      }

      .magazine-page {
        width: 100%;
        max-width: 794px; /* A4 width */
        height: 1123px; /* A4 height fixed */
        background-color: var(--bg-color);
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        padding: 60px 55px 50px 55px; /* Same padding */
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        position: relative; /* for absolute controls */
        transition: background-color 0.3s ease, color 0.3s ease;
      }

      /* Toggles Container */
      .toggles {
        position: absolute;
        top: 20px;
        right: 25px;
        display: flex;
        gap: 15px;
        z-index: 100;
        font-family: 'Noto Sans KR', sans-serif;
        font-size: 12px;
        font-weight: 600;
      }

      .toggles button, .toggles a {
        background: none;
        border: 1px solid var(--text-color);
        color: var(--text-color);
        cursor: pointer;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 10px;
        text-transform: uppercase;
        transition: all 0.2s;
        text-decoration: none;
      }

      .toggles button:hover, .toggles a:hover {
        background: var(--text-color);
        color: var(--bg-color);
      }

      /* Typography Setup using Typetura properties */
      .logo {
        font-family: 'Montserrat', sans-serif;
        font-size: 38px;
        font-weight: 800;
        font-style: italic;
        letter-spacing: -2px;
        color: var(--text-color);
        margin: 5px 0 20px 0;
      }

      .meta-info {
        font-family: 'Noto Sans KR', sans-serif;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-color);
        text-transform: uppercase;
        margin-bottom: 5px;
        letter-spacing: 1px;
      }

      /* Capsize Trimmed Title */
      .main-copy {
        font-family: 'Noto Serif KR', serif;
        font-weight: 700;
        letter-spacing: -1px;
        color: var(--text-color);
        /* Capsize Generated Styles mapped to vars */
        line-height: 50px;
        font-size: 44px;
      }
      .main-copy::before {
        content: var(--valBefore);
        display: table;
        margin-bottom: var(--marginBottomBefore);
      }
      .main-copy::after {
        content: var(--valAfter);
        display: table;
        margin-top: var(--marginTopAfter);
      }

      .sub-copy {
        font-family: 'Noto Sans KR', sans-serif;
        font-size: 14px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--text-color);
        margin: 15px 0 0 0;
      }

      /* Layout Sections */
      .top-section {
        flex: 0 0 calc(20% - 15px);
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        text-align: left;
      }

      .middle-section {
        flex: 0 0 52%;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }
      .middle-section img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .bottom-section {
        flex: 1;
        display: flex;
        gap: 30px;
        padding-top: 30px;
        overflow: hidden;
      }

      .bottom-left {
        flex: 1.05;
        display: flex;
        overflow: hidden;
      }
      .bottom-left img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .bottom-right {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        padding-left: 10px;
        text-align: left;
      }

      .bottom-right .title {
        font-family: 'Noto Serif KR', serif;
        font-size: 34px;
        font-weight: 600;
        color: var(--text-color);
        margin: 0 0 15px 0;
        line-height: 1.15;
        letter-spacing: -0.5px;
      }

      .bottom-right .subtitle {
        font-family: 'Noto Sans KR', sans-serif;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--text-color);
        margin: 0 0 10px 0;
      }

      .bottom-right .description {
        font-family: 'Noto Sans KR', sans-serif;
        font-weight: 400;
        color: var(--text-color);
        margin: 0;
        /* Capsize mapping for Body */
        font-size: 11px;
        line-height: 18px;
      }
      .bottom-right .description::before {
        content: var(--bValBefore);
        display: table;
        margin-bottom: var(--bMarginBottomBefore);
      }
      .bottom-right .description::after {
        content: var(--bValAfter);
        display: table;
        margin-top: var(--bMarginTopAfter);
      }

      .footer-links {
        margin-top: auto;
        padding-bottom: 2px;
        font-family: 'Montserrat', sans-serif;
        font-size: 8.5px;
        font-weight: 700;
        color: var(--text-color);
        letter-spacing: 0.5px;
      }

      /* Responsive Mobile Reflow */
      @media (max-width: 768px) {
        body { padding: 0; }
        .magazine-page {
          height: auto;
          min-height: 100vh;
          padding: 60px 25px 40px 25px;
        }
        .top-section { margin-bottom: 30px; }
        .main-copy { font-size: 32px; line-height: 1.2; }
        /* Disable aggressive Capsize trimming on mobile */
        .main-copy::before, .main-copy::after, .bottom-right .description::before, .bottom-right .description::after { 
          display: none !important; margin: 0 !important; content: none !important; 
        }
        .middle-section { flex: none; aspect-ratio: 4 / 3; margin-bottom: 30px; }
        .bottom-section { flex: none; flex-direction: column; padding-top: 0; gap: 20px; }
        .bottom-left { flex: none; aspect-ratio: 16 / 9; }
        .bottom-right { padding-bottom: 20px; }
        .bottom-right .description { font-size: 13.5px; line-height: 22px; }
        .footer-links { margin-top: 30px; font-size: 10px; }
      }
    </style>
  </head>
  <body>
    <!-- Typetura root context class -->
    <div class="typetura-container magazine-page">
      
      <!-- Toggles positioned inside absolute but top relative to canvas -->
      <div class="toggles">
        <a href={base}>Index</a>
        <button id="themeToggle">Dark/Light</button>
        <button id="langToggle">EN/KR</button>
      </div>

      <!-- Top Section: Metadata & Header -->
      <header class="top-section">
        <div class="logo">HAKO</div>
        <div class="meta-info">
          <span class="lang-ko">{category} | {new Date(date).toLocaleDateString()}</span>
          <span class="lang-en">{categoryEn} | {new Date(date).toLocaleDateString()}</span>
        </div>
        <h1 class="main-copy">
          <span class="lang-ko">{title}</span>
          <span class="lang-en">{titleEn || title}</span>
        </h1>
        <div class="sub-copy">
          <span class="lang-ko">MAGAZINE EDITORIAL</span>
          <span class="lang-en">MAGAZINE EDITORIAL</span>
        </div>
      </header>

      <!-- Middle Section: Main Cover Image -->
      <section class="middle-section">
        <img src={safeCover} alt="Main Visual" />
      </section>

      <!-- Bottom Section: Detail Image & Post Meta Desc -->
      <section class="bottom-section">
        <div class="bottom-left">
          <img src={safeSub} alt="Detail View" />
        </div>
        
        <div class="bottom-right">
          <h2 class="title" style="white-space: pre-wrap">
            <span class="lang-ko">{subtitle}</span>
            <span class="lang-en">{subtitleEn || subtitle}</span>
          </h2>
          <!-- <h3 class="subtitle">Detailed Breakdown</h3> -->
          <p class="description">
            <span class="lang-ko">{description}</span>
            <span class="lang-en">{descriptionEn || description}</span>
          </p>
          
          <div class="footer-links">
            <a href="https://www.instagram.com/hakorium" target="_blank" style="color:inherit; text-decoration:none;">hakorium.com</a> &nbsp;|&nbsp; <span>Available Online Now</span>
          </div>
        </div>
      </section>
      
      <!-- Slot for direct markdown content if the user wants to see it,
           Though this layout is strictly simulating an A4 spread limit. -->
      <div style="display:none;"><slot /></div>

    </div>

    <!-- Logic for Toggles -->
    <script>
      const html = document.documentElement;
      
      document.getElementById('themeToggle')?.addEventListener('click', () => {
        const currentTheme = html.getAttribute('data-theme');
        html.setAttribute('data-theme', currentTheme === 'light' ? 'dark' : 'light');
      });

      document.getElementById('langToggle')?.addEventListener('click', () => {
        const currentLang = html.getAttribute('data-lang');
        html.setAttribute('data-lang', currentLang === 'ko' ? 'en' : 'ko');
      });
    </script>
  </body>
</html>
